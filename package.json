{
  "name": "@ht-rnd/merge-conflict-viewer",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "description": "A comprehensive merge conflict viewer component for React applications",
  "author": "",
  "license": "Apache-2.0",
  "keywords": [
    "react",
    "merge",
    "conflict",
    "diff",
    "viewer",
    "json",
    "comparison"
  ],
  "main": "./dist/lib/main.umd.js",
  "module": "./dist/lib/main.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/lib/main.es.js",
      "require": "./dist/lib/main.umd.js"
    },
    "./styles": "./dist/merge-conflict-viewer.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "vite --host --logLevel info",
    "build": "biome ci && vite build",
    "build:ci": "vite build",
    "check": "biome check --write",
    "check:ci": "biome ci",
    "format": "biome format --write",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deep-diff": "^1.0.2",
    "lucide-react": "^0.574.0",
    "radix-ui": "^1.4.3",
    "react-diff-view": "^3.3.2",
    "tailwind-merge": "^3.4.1",
    "unidiff": "^1.0.4"
  },
  "optionalDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/deep-diff": "^1.0.5",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
